# CoteCerto — deploy/.env.example (K6-a)
#
# Copie para "deploy/.env" (NUNCA commitar o .env real) e preencha os
# valores. Usado por docker-compose.supabase.yml E docker-compose.app.yml
# (passe com --env-file deploy/.env nos dois comandos).
#
# Ver docs/RUNBOOK_DEPLOY.md, seção "Gerando segredos", para os comandos de
# geração de cada valor sensível.

############################################
# Supabase self-hosted — segredos "raiz"
############################################

# Senha do superuser postgres (e demais roles internas). Gerar novo com:
#   openssl rand -base64 32
POSTGRES_PASSWORD=

# Chave simétrica HS256 usada por GoTrue/PostgREST/Realtime/Storage/Kong
# para assinar e validar JWTs. Se quiser que os usuários existentes num
# Supabase atual continuem válidos, esta chave PRECISA ser a mesma do
# ambiente de origem — ver runbook, seção "Fidelidade da réplica".
# Gerar novo com: openssl rand -base64 48 (min. 32 caracteres)
JWT_SECRET=

# Chaves de API (JWTs HS256 assinados com o JWT_SECRET acima, role "anon"
# e "service_role"). Gerar com o utilitário do template oficial do Supabase
# (utils/generate-keys.sh) ou com um gerador de JWT HS256 compatível,
# usando o MESMO JWT_SECRET. Precisam bater com o SELF_SUPABASE_* /
# VITE_SUPABASE_* usados pelo app (ver seção "App" abaixo).
ANON_KEY=
SERVICE_ROLE_KEY=

# Chaves opacas novas (opcional; deixar em branco se não for usar o novo
# esquema de API keys do Supabase — o legado ANON_KEY/SERVICE_ROLE_KEY acima
# já é suficiente).
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=

# Credenciais do Supabase Studio (dashboard). Gerar senha nova com:
#   openssl rand -base64 24
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

# Usado por Realtime/Supavisor para cifrar dados internos. Gerar com:
#   openssl rand -base64 48   (mín. 64 caracteres)
SECRET_KEY_BASE=

# Chave de criptografia do schema _realtime. Deve ter EXATAMENTE 16
# caracteres. Gerar com: openssl rand -hex 8
REALTIME_DB_ENC_KEY=supabaserealtime

# Reservado (Supavisor não está habilitado nesta stack — ver comentário no
# docker-compose.supabase.yml). Deixe em branco ou gere por padronização:
#   openssl rand -hex 16 (32 caracteres)
VAULT_ENC_KEY=

# Chave de criptografia usada pelo Studio para falar com postgres-meta.
# Mín. 32 caracteres. Gerar com: openssl rand -base64 24
PG_META_CRYPTO_KEY=

# Credenciais do endpoint S3 (protocolo) exposto pelo Storage. Só relevante
# se algum client usar a API S3 do Storage diretamente.
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############################################
# Supabase self-hosted — URLs
############################################

# URL pública do gateway (Kong) — como o navegador/app acessa a API. Se o
# nginx expõe o Kong em https://SEU_DOMINIO/ (sem subpath), use o domínio
# raiz; ajuste conforme a estrutura de rotas escolhida no nginx.
SUPABASE_PUBLIC_URL=https://SEU_DOMINIO

# URL externa completa do serviço de Auth (usada em callbacks OAuth/SAML e
# nos links de e-mail).
API_EXTERNAL_URL=https://SEU_DOMINIO/auth/v1

############################################
# Supabase self-hosted — Postgres
############################################

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############################################
# Supabase self-hosted — Studio
############################################

STUDIO_DEFAULT_ORGANIZATION=CoteCerto
STUDIO_DEFAULT_PROJECT=CoteCerto
# Opcional — habilita o AI Assistant do Studio.
OPENAI_API_KEY=

############################################
# Supabase self-hosted — Auth (GoTrue)
############################################

# Site URL / redirect URLs do app (front). Ajustar para o domínio real.
SITE_URL=https://SEU_DOMINIO
ADDITIONAL_REDIRECT_URLS=

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# SMTP real (produção) — sem isso, e-mails de confirmação/recuperação de
# senha não são enviados.
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=CoteCerto

############################################
# Supabase self-hosted — PostgREST
############################################

PGRST_DB_SCHEMAS=public,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############################################
# Supabase self-hosted — Storage
############################################

# STORAGE_BACKEND=file (padrão do compose). Usado como nome do diretório.
GLOBAL_S3_BUCKET=cotecerto-storage
REGION=local
STORAGE_TENANT_ID=cotecerto

############################################
# Supabase self-hosted — Edge Functions
############################################

# "false" em produção normalmente deve ser "true" se as functions exigirem
# JWT válido; ajustar conforme uso real (hoje o repo não usa Edge Functions).
FUNCTIONS_VERIFY_JWT=false

############################################
# Supabase self-hosted — imgproxy
############################################

IMGPROXY_AUTO_WEBP=true

############################################
# App (imagem GHCR) — runtime
############################################

# Tag da imagem a subir (ex.: "latest", "sha-abc1234", "v1.2.0"). Ver
# docs/RUNBOOK_DEPLOY.md para a política de tags e rollback.
APP_IMAGE_TAG=latest

# Runtime-only (server functions do app — src/lib/cadastro.functions.ts,
# src/lib/admin-users.functions.ts). Apontam para o Supabase desta mesma
# stack, via rede Docker interna (Kong).
SELF_SUPABASE_URL=http://kong:8000
SELF_SUPABASE_SERVICE_ROLE_KEY=
# ^ deve ser IGUAL ao SERVICE_ROLE_KEY definido acima.

############################################
# nginx / TLS
############################################

# Domínio que aponta pro servidor (DNS A/AAAA). Usado nos comandos certbot
# e no vhost do nginx (deploy/nginx/conf.d/app.conf).
PROXY_DOMAIN=seu-dominio.example.com
CERTBOT_EMAIL=admin@example.com

############################################
# Build da imagem (CI — NÃO usado neste deploy, referência)
############################################

# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY são embutidas no bundle em
# build-time pelo CI (.github/workflows/docker.yml, via vars/secrets do
# GitHub) — não fazem parte do runtime deste .env. Se precisar rebuildar a
# imagem localmente apontando para este Supabase self-hosted, use:
#   VITE_SUPABASE_URL=https://SEU_DOMINIO
#   VITE_SUPABASE_ANON_KEY=<mesmo valor de ANON_KEY acima>
